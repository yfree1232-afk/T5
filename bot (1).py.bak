        print("   🤖 𝒜𝐼 𝒞𝒽𝒶𝓉 𝓌𝒾𝓉𝒽 𝒢𝑒𝓂𝒾𝓃𝒾")
        print("   🛡️ 𝐶𝑜𝓂𝓅𝓁𝑒𝓉𝑒 𝑀𝑜𝒹𝑒𝓇𝒶𝓉𝒾𝑜𝓃 𝒯𝑜𝑜𝓁𝓈")
        print("   💖 𝒲𝑒𝓁𝒸𝑜𝓂𝑒/𝐹𝒶𝓇𝑒𝓌𝑒𝓁𝓁 𝑀𝑒𝓈𝓈𝒶𝑔𝑒𝓈")
        print("   💖 𝒞𝑜𝓊𝓅𝓁𝑒 𝓸𝒻 𝓽𝒽𝓮 𝒟𝒶𝓎")
